# ============================================
#  study_rag 环境变量模板
#
#  使用方法：
#    cp .env.example .env
#    # 按需修改后：
#    docker compose --env-file .env -f docker/docker-compose.yml up -d
#
#  说明：
#    - 所有 STUDY_RAG_* 前缀的变量由 pydantic-settings 读取（settings.py）
#    - YAML 配置文件内支持 ${VAR} 占位符（由 embedding/base.py 解析）
#    - 未列出的变量保持代码默认值
# ============================================

# ---- 服务运行 ----
# admin REST 监听地址（容器内通常用 0.0.0.0）
STUDY_RAG_HOST=0.0.0.0
STUDY_RAG_PORT=3200
STUDY_RAG_LOG_LEVEL=INFO
# uvicorn worker 数（MCP standalone 不受此项影响，固定 1）
STUDY_RAG_WORKERS=1

# MCP standalone 独立端口（entrypoint.sh 读取）
MCP_HOST=0.0.0.0
MCP_PORT=3220

# ---- 鉴权 ----
# admin REST Bearer Token；未设置则不启用鉴权（开发模式）
# 生产环境务必设置一个强随机串：openssl rand -hex 32
STUDY_RAG_ADMIN_TOKEN=

# 是否强制 MCP Tool 的 api_key 非空（默认 false=允许匿名）
# 生产环境接入 JWT/OAuth 后设为 true
STUDY_RAG_MCP_REQUIRE_API_KEY=false

# ---- 限流（令牌桶） ----
# admin REST：突发上限 / 稳态 QPS
STUDY_RAG_ADMIN_RATELIMIT_CAPACITY=120
STUDY_RAG_ADMIN_RATELIMIT_PER_SEC=2.0
# MCP 检索：突发上限 / 稳态 QPS
STUDY_RAG_SEARCH_RATELIMIT_CAPACITY=30
STUDY_RAG_SEARCH_RATELIMIT_PER_SEC=5.0

# ---- 熔断器 ----
# OpenAI / Embedding 链路
STUDY_RAG_OPENAI_BREAKER_THRESHOLD=5
STUDY_RAG_OPENAI_BREAKER_TIMEOUT_S=30.0
# 检索链路
STUDY_RAG_SEARCH_BREAKER_THRESHOLD=10
STUDY_RAG_SEARCH_BREAKER_TIMEOUT_S=20.0

# ---- 向量库（vector_store.yaml 也可通过 ${VAR} 引用） ----
# Milvus Standalone 地址（docker-compose --profile vector 启动后用服务名）
MILVUS_URI=http://milvus:19530
# Milvus / Zilliz 鉴权 token（无鉴权可留空）
MILVUS_TOKEN=
MILVUS_DB=default
# Zilliz Cloud 托管服务
# ZILLIZ_TOKEN=

# Qdrant（如使用 qdrant provider）
# QDRANT_API_KEY=

# ---- Embedding 后端 API Key（按实际使用的 provider 取消注释） ----
# OpenAI / Azure OpenAI
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
# 阿里通义千问（DashScope，OpenAI 兼容）
DASHSCOPE_API_KEY=
# 智谱 AI
ZHIPUAI_API_KEY=
# Cohere（reranker）
COHERE_API_KEY=

# ---- 本地自建推理服务（OpenAI 兼容协议） ----
# embeddings.yaml / reranker.yaml 里 local_* 配置引用
LOCAL_EMBED_API_KEY=
LOCAL_RERANK_API_KEY=
# HTTP reranker fallback（impls_http.py 读取）
RERANK_HTTP_BASE_URL=

# ---- Ollama（本地 embedding，OpenAI 兼容端点） ----
# embeddings.yaml 中 ollama_bge_large 用 http://localhost:11434/v1
# 容器内访问宿主机 Ollama 改为 http://host.docker.internal:11434/v1
